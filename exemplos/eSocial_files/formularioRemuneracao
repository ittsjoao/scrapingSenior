function RegraDataMenorIgualPeriodo(periodo) {
    // REGRA_DATA_MENOR_IGUAL_PERIODO
    var inicioPerApur = new Date();
    var inicioPerAnt = new Date();

    var periodoDemonstrativo = $("#RubricaAcessoria_PeriodoApuracao").val();

    if (periodoDemonstrativo.length > 4) {
        if (new RegExp("(1[0-2]|0[1-9])\/[0-9]{4}").test(periodoDemonstrativo)) {
            inicioPerAnt = new Date(periodoDemonstrativo.substr(3, 4), periodoDemonstrativo.substr(0, 2) - 1, 1);
        }
    }
    else {
        inicioPerAnt = new Date(periodoDemonstrativo, 11, 1);
    }

    var periodoApuracao = $("#EventoAcessorio_PeriodoApuracao").val();

    if (periodoApuracao.length > 4) {
        inicioPerApur = new Date(periodoApuracao.substr(0, 4), periodoApuracao.substr(4, 2) - 1, 1);
    }
    else {
        inicioPerApur = new Date(periodoApuracao, 11, 1);
    }

    if (inicioPerAnt > inicioPerApur) {
        return false;
    }

    return true;
}

