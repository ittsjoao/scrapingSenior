/*
Parametros para configuração do autocomplete:

- idCampoValorSelecionado (obrigatório)
    Id do campo que vai receber o valor selecionado no autocomplete.

- idCampoAutoComplete  (obrigatório)
    Id do campo onde o autocomplete vai ser aplicado.

- urlConsulta (obrigatório)
    Url de onde a consulta para carregar os itens vai ser realizada.

- idCamposParametro
    Quando a url para consulta precisar de mais de um parâmetro, passar um array com os ids dos parametros na ordem desejada. 
    A url deve ser informada da seguinte forma: http://localhost/?param1={0}&param2={1}
    Caso o valor não seja informado será utilizado o valor do campo idCampoValorSelecionado como padrão.

- placeholder
    Texto esmaecido que vai ser exibido no campo do autocomplete.
    Caso o valor não seja informado será utilizado o texto "Informe valor" como padrão.

- submeterFormulario
    Indica se o autocomplete deve fazer um submit após a seleção do item.
    Caso o valor não seja informado será utilizado o valor true como padrão.

- tamanhoTextoParaPesquisa
    Indica a quantidade minima de caracteres que deve ser informada antes de realizar a consulta.
    Caso o valor não seja informado será utilizado o valor 1 como padrão.

- delayParaPesquisa
    Indica o tempo (ms) de espera entre a última tecla digitada pelo usuário e o início da consulta.
    Caso o valor não seja informado será utilizado o valor 1000 como padrão.

- classeAutoComplete
    Indica as classes (css) que devem ser incluidas no campo autocomplete.

- metodoMontarItens
    Nome do metodo responsável por montar os itens do autocomplete
    Caso o valor não seja informado será utilizado o metodo MontarItensAutoCompleteGenerico como padrão.

- metodoPesquisaSemResultado
    Nome do método que deve ser executado quando a pesquisa não tem resultado.
    Caso o valor não seja informado, nenhuma ação adicional será tomada.

- permitirPesquisaParcial
    Indica se a pesquisa parcial (isto é, sem que seja feita a seleção de um item) possa ser feita (teclar o "Enter" ou acionar a "lupa de pesquisa" implica submissão do formulário)
    Caso o valor não seja informado, a pesquisa parcial não será permitida.

- exibirDescricaoCompleta
    Indica se, após a seleção de um valor dentre os amostrados, o campo idCampoAutoComplete será preenchido com todo o valor amostrado (não somente o código).
    Caso o valor não seja informado será utilizado o valor false como padrão.

- iniciarValorCampoAutoComplete
    Indica se, durante a configuração do autoComplete (geralmente feita após o carregamento do html), o valor do campo idCampoAutoComplete será carregado com o valor do campo idCampoValorSelecionado.
    Caso o valor não seja informado será utilizado o valor true como padrão.

Callback:
    Caso seja necessário realizar alguma ação após a seleção do autocomplete a implementação do metodo de callback deve ter o seguinte nome:
    "AutoCompleteSelectCallBack_" + idCampoValorSelecionado

*/


$.widget("custom.AutoCompleteCategoria", $.ui.autocomplete, {
    _create: function () {
        this._super();
        this.widget().menu("option", "items", "> :not(.ui-autocomplete-category)");
    },
    _renderMenu: function (ul, items) {
        var that = this,
            currentCategory = "";
        $.each(items, function (index, item) {
            var li;
            if (item.category != currentCategory) {
                ul.append("<li class='ui-autocomplete-category'><a>" + item.category + "</a></li>");
                currentCategory = item.category;
            }
            li = that._renderItemData(ul, item);
            if (item.category) {
                li.attr("aria-label", item.category + " : " + item.label);
            }
        });
    }
});

function SetarConfiguracoesOpcionais(config) {
    config.idCamposParametro = (config.idCamposParametro == undefined) ? [config.idCampoAutoComplete] : config.idCamposParametro;
    config.placeholder = (config.placeholder == undefined) ? "Informe o valor" : config.placeholder;
    config.submeterFormulario = (config.submeterFormulario == undefined) ? true : config.submeterFormulario;
    config.tamanhoTextoParaPesquisa = (config.tamanhoTextoParaPesquisa == undefined) ? 1 : config.tamanhoTextoParaPesquisa;
    config.delayParaPesquisa = (config.delayParaPesquisa == undefined) ? 1000 : config.delayParaPesquisa;
    config.exibirDescricaoCompleta = (config.exibirDescricaoCompleta == undefined) ? false : true;
    config.permitirPesquisaParcial = (config.permitirPesquisaParcial == undefined) ? false : config.permitirPesquisaParcial;
    config.iniciarValorCampoAutoComplete = (config.iniciarValorCampoAutoComplete == undefined) ? true : config.iniciarValorCampoAutoComplete;
    
    return config;
}

function AutoComplete(config) {

    config = SetarConfiguracoesOpcionais(config);

    if (config.classeAutoComplete != undefined) {
        $("#" + config.idCampoAutoComplete).addClass(config.classeAutoComplete);
    }

    if (config.permitirPesquisaParcial) {
        var autoCompleteBotaoPesquisa = $('<div class="autocomplete-botao-pesquisa"></div>');

        autoCompleteBotaoPesquisa.on('click', function () {
            if ($("#" + config.idCampoAutoComplete).is(':not(:disabled)')) {
                PrepararPesquisaAutoComplete(config);

                // Incluir classe no input relacionado para que não seja impedida a submissão por uma possível validação jQuery
                $("#" + config.idCampoAutoComplete).addClass('data-val-ignore');

                $('form:first').submit();
            }
        });

        if ($("#" + config.idCampoAutoComplete).parent().find(".autocomplete-botao-pesquisa").length == 0)
        {
            $("#" + config.idCampoAutoComplete).parent().append(autoCompleteBotaoPesquisa);
        }
    }

    $("#" + config.idCampoAutoComplete).keypress(function (e) {
        if (e.which == 13) {
            if (!config.permitirPesquisaParcial) {
                e.stopPropagation();
                return false;
            }
            else {
                PrepararPesquisaAutoComplete(config);

                // Incluir classe no input relacionado para que não seja impedida a submissão por uma possível validação jQuery
                $("#" + config.idCampoAutoComplete).addClass('data-val-ignore');
            }
        }
    });

    // Limpeza do campo que contém de fato o valor selecionado caso o campo que recebeu o autocomplete seja completamente limpo
    $("#" + config.idCampoAutoComplete).blur(function () {
        if ($(this).val() == '') {
            $("#" + config.idCampoValorSelecionado).val('').change();
            $(this).parent().find('#valorFoiSelecionado').val('').removeAttr('value')
        }
    });

    if (config.iniciarValorCampoAutoComplete) {
        $("#" + config.idCampoAutoComplete).val($("#" + config.idCampoValorSelecionado).val());
    }

    $("#" + config.idCampoAutoComplete).parent().append('<input type="hidden" name="valorFoiSelecionado" id="valorFoiSelecionado"/>');
    $("#" + config.idCampoAutoComplete).attr('placeholder', config.placeholder)
                                .AutoCompleteCategoria({
                                    minLength: config.tamanhoTextoParaPesquisa,
                                    delay: config.delayParaPesquisa,
                                    source: function (request, response) {
                                        if (config.idCampoAutoComplete == "NumeroInscricao") {
                                            // MinLength controlado na mão pois o campo possui máscara
                                            var valorNumeroInscricao = $("#NumeroInscricao").val().replace(/\D/g, "");

                                            if (valorNumeroInscricao.length < 3) {
                                                response([]);
                                                return;
                                            }
                                        }

                                        var indiceCamposParametro = 0;
                                        var arrValores = [];

                                        for (indiceCamposParametro; indiceCamposParametro < config.idCamposParametro.length; indiceCamposParametro++) {
                                            if (config.idCamposParametro[indiceCamposParametro] == "NumeroInscricao") {
                                                arrValores.push($('#' + config.idCamposParametro[indiceCamposParametro]).val().replace(/\D/g, ""));
                                            } else {
                                                // Usado o método encodeURIComponent nos parâmetros a serem enviados para o servidor para que não
                                                // sejam mal interpretados os caracteres especiais que possam compor a ulr final
                                                arrValores.push(encodeURIComponent($('#' + config.idCamposParametro[indiceCamposParametro]).val()));
                                            }
                                        }

                                        $.getJSON(format(config.urlConsulta, arrValores), function (data) {
                                            var items = [];

                                            if (data.length > 0) {
                                                if (config.metodoMontarItens == undefined) {
                                                    items = MontarItensAutoCompleteGenerico(data);
                                                }
                                                else {
                                                    if (typeof config.metodoMontarItens === "function") {
                                                        items = config.metodoMontarItens(data);
                                                    }
                                                }
                                            }
                                            else if (typeof config.metodoPesquisaSemResultado === "function") {
                                                config.metodoPesquisaSemResultado();
                                            }

                                            response(items);
                                        });
                                    },
                                    select: function (event, ui) {
                                        $('#Pagina').val(1);
                                       
                                        $("#" + config.idCampoValorSelecionado).val(ui.item.valorEfetivo);
                                            
                                        if (ui.item.valorEfetivo == 0) {
                                            $("#idTrabalhador").val(ui.item.outros );
                                        }
                                        $("#valorFoiSelecionado").val('true');
                                        if (config.submeterFormulario) {
                                            $("#" + config.idCampoValorSelecionado).attr('maxlength', ui.item.valorEfetivo.length);
                                            $('form:first').submit();
                                        }
                                        else {
                                            var arguments = [];
                                            arguments.push(event);
                                            arguments.push(ui);

                                            var nomeMetodo = "AutoCompleteSelectCallBack_" + config.idCampoValorSelecionado;

                                            if (typeof window[nomeMetodo] === "function") {
                                                window[nomeMetodo](arguments);
                                            }
                                        }

                                        if (!config.exibirDescricaoCompleta) {
                                            $("#" + config.idCampoAutoComplete).val(ui.item.id);
                                        }
                                        else
                                        {
                                            if (config.idCampoAutoComplete == config.idCampoValorSelecionado) {
                                                $("#" + config.idCampoAutoComplete).val(ui.item.id);
                                            }
                                            else {
                                                $("#" + config.idCampoAutoComplete).val(ui.item.label);                                                
                                            }
                                        }


                                        return false;
                                    },
                                    response: function (event, ui) {
                                        if (ui.content.length === 0) {
                                            if ($(event.target).parent().find('.autocomplete-vazio').length == 0) {
                                                $("#" + config.idCampoAutoComplete).parent().append("<div class='autocomplete-vazio hide'>Nenhum resultado encontrado.</div>")
                                            }
                                            $(event.target).parent().find('.autocomplete-vazio').removeClass("hide");
                                        } else {
                                            $(event.target).parent().find('.autocomplete-vazio').addClass("hide");
                                        }
                                    },
                                    open: function (e, ui) {
                                        var acData = $(this).data('customAutoCompleteCategoria');
                                        acData
                                            .menu
                                            .element
                                            .find('a')
                                            .each(function () {
                                                var me = $(this);
                                                var keywords = acData.term.split(' ').join('|');
                                                me.html(me.text().replace(new RegExp("(" + keywords + ")", "gi"), '<span class="termo-pesquisa-destacado">$1</span>'));
                                            });
                                    }
                                });
}


function MontarItensAutoCompleteGenerico(data) {
    var items = [];
    $.each(data, function (Value, item) {
        var texto;
        if (item.Text != null && item.Text != "") {
            texto = item.Value + " - " + item.Text;
        } else {
            texto = item.Value;
        }


        if (typeof item.DataInicioValidade !== 'undefined' && item.DataInicioValidade != null && item.DataInicioValidade.length > 0) {
            texto = texto + " - Início: " + item.DataInicioValidade;
        }

        if (typeof item.DataFimValidade !== 'undefined' && item.DataFimValidade != null && item.DataFimValidade.length > 1) {
            texto = texto + " Fim:" + item.DataFimValidade;
        }

        var obj = {
            value: texto,
            label: texto,
            id: item.Value,
            valorEfetivo: item.Value,
            category: (item.Group != undefined) ? item.Group.Name : "",
            outros: item.Outros
        };
        items.push(obj);
    });

    return items;
}

function PrepararPesquisaAutoComplete(config) {
    $('#Pagina').val(1);
    $("#" + config.idCampoValorSelecionado).val($("#" + config.idCampoAutoComplete).val());
    $("#valorFoiSelecionado").val('false');
};
