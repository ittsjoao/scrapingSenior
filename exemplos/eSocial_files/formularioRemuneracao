function preencherNumeroNotificacaoAfastamentoFgtsRemuneracao(identificadorDemonstrativo) {
    if (!identificadorDemonstrativo) return;

    var demonstrativosSerializados = $("#DemonstrativosSerializados").val();

    if (demonstrativosSerializados) {
        try {
            var demonstrativos = JSON.parse(demonstrativosSerializados);

            var demonstrativoEncontrado = demonstrativos.find(function (dem) {
                return dem.IdentificadorDemonstrativo === identificadorDemonstrativo;
            });

            if (demonstrativoEncontrado && demonstrativoEncontrado.NumeroNotificacaoAfastamentoFGTS) {
                $("#EventoAcessorio_DemonstrativosValoresDevidos_0__NumeroNotificacaoAfastamentoFGTS")
                    .val(demonstrativoEncontrado.NumeroNotificacaoAfastamentoFGTS);
            } else {
                $("#EventoAcessorio_DemonstrativosValoresDevidos_0__NumeroNotificacaoAfastamentoFGTS").val("");
            }
        } catch (e) {
            console.error("Erro ao processar demonstrativos:", e);
        }
    }
}

