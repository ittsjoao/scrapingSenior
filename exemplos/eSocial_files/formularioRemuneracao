    cabecalho += '<th scope="col">Ação</th>';
    cabecalho += '</tr>';

    return cabecalho;
}

function CallbackIncluirAdvogado(data) {
    if (data != null && data.Sucesso) {
        var novaLinha = $("<tr>");
        var novaLinhaCabecalho = $("<thead>");
        var cabecalho = "";
        var cols = "";
        var tipoInscricao = "Cnpj";
        var quantidade = 0;

        if (data.Objeto['TipoInscricao'] == 2) {
            tipoInscricao = "Cpf";
        }

        var listaAdvogado = [];

        if ($("#ListaAdvogadoSerializada").val() != undefined && $("#ListaAdvogadoSerializada").val() != '') {
            listaAdvogado = JSON.parse($("#ListaAdvogadoSerializada").val());
            quantidade = listaAdvogado.length;
            listaAdvogado[quantidade] = data.Objeto;
        }
        else {
            listaAdvogado[0] = data.Objeto;
        }

        if (quantidade == 0) {
            cabecalho += CabecalhoTabelaAdvogado();
            novaLinhaCabecalho.append(cabecalho);
            $("#idListaAdvogado").append(novaLinhaCabecalho);

        }

        cols += '<td class="center"><span><a class="linkEditar" title="" href="javascript:void(0)" data-original-title="Editar" onclick="EditarAdvogado(' + data.Objeto['TipoInscricao'] + ',\'' + data.Objeto['NumeroInscricao'] + '\',' + data.Objeto['ValorDespesaAdvogado'] + ',' + quantidade + ')"><span>' + tipoInscricao + '</span></a></span></td>';
        cols += '<td class="center"><span><a class="linkEditar" title="" href="javascript:void(0)" data-original-title="Editar" onclick="EditarAdvogado(' + data.Objeto['TipoInscricao'] + ',\'' + data.Objeto['NumeroInscricao'] + '\',' + data.Objeto['ValorDespesaAdvogado'] + ',' + quantidade + ')"><span>' + data.Objeto['NumeroInscricao'] + '</span></a></span></td>';
        cols += '<td class="center"><span><a class="linkEditar" title="" href="javascript:void(0)" data-original-title="Editar" onclick="EditarAdvogado(' + data.Objeto['TipoInscricao'] + ',\'' + data.Objeto['NumeroInscricao'] + '\',' + data.Objeto['ValorDespesaAdvogado'] + ',' + quantidade + ')"><span>' + FormatarMoeda(data.Objeto['ValorDespesaAdvogado']) + '</span></a></span></td>';
        cols += '<td class="center acoes"><a class="acao" href = "javascript:void(0)" data-original-title="Excluir" onclick = "ConfirmarExclusaoAdvogado(' + quantidade + ',\'advogado\')"> Excluir</a></td>';
        novaLinha.append(cols);
        $("#idListaAdvogado").append(novaLinha);

        $("#ListaAdvogadoSerializada").val(JSON.stringify(listaAdvogado));

        $("#mensagemClicarAdvogado").removeClass("hide").show();

        LimparEdicaoAdvogado();
    }
    else {
        $("#mensagemClicarAdvogado").addClass("hide").hide();
    }
}

function ValidarAdvogado() {
    var tipoInscricao = $("[id$='InformacaoAdvogadoRRAAcessoria_TipoInscricao']").valid();
    var numeroInscricao = $("[id$='InformacaoAdvogadoRRAAcessoria_NumeroInscricao']").valid();
    var valorDespesas = $("[id$='InformacaoAdvogadoRRAAcessoria_ValorDespesaAdvogado']").valid();
    var existeNumeroInscricaoTabela = false;

    if ($("#ListaAdvogadoSerializada").val() != undefined && $("#ListaAdvogadoSerializada").val() != '') {
        var listaAdvogado = JSON.parse($("#ListaAdvogadoSerializada").val());

        var numeroInscricaoSemFormatacao = $("[id$='InformacaoAdvogadoRRAAcessoria_NumeroInscricao']").val().replace(".", "").replace(".", "").replace("-", "").replace("/", "");
        //existeNumeroInscricaoTabela = ExisteNumeroInscricao(listaAdvogado, $("[id$='InformacaoAdvogadoRRAAcessoria_NumeroInscricao']").val()) != -1;

        existeNumeroInscricaoTabela = ExisteNumeroInscricao(listaAdvogado, numeroInscricaoSemFormatacao) != -1;
    }

    return (tipoInscricao && numeroInscricao && valorDespesas && !existeNumeroInscricaoTabela) ? true : false;
}


function LimparEdicaoAdvogado() {
    // Admissão e desdobramentos
    if ($("#idAdvogado").length > 0) {
        $("#btnIncluirAdvogado").show();
        $("#btnEditarAdvogado, #btnCancelarAdvogado").hide();
        $('#PreencherInformacaoAdvogados').prop('checked', false);
        $("#idAdvogado").addClass('hide');
        $('#idAdvogado').find('input:text, select').val('').removeAttr("readonly");
        LimparCampos('#idAdvogado');
    }
}

function PrepararInclusaoRRA(limparCampos, registrarEntidade) {
    //Verifica se já está na entidade 'informacoes-complementares-rra'
    // se sim é resultado de um submite da tabela de advogado
    // então não limpa os campos
    if ($("#EntidadeOperacao").val() == 'informacoes-complementares-rra') {
        limparCampos = false;
    }

    if (registrarEntidade) {
        $("#EntidadeOperacao").val("informacoes-complementares-rra");
    }

    if (limparCampos) {
        $("#InformacaoRRAAcessoria_Identificador").focus();
        $("#InformacaoRRAAcessoria_Identificador").selectedIndex = 0;
        $("#InformacaoRRAAcessoria_InformacaoRRA_TipoProcessoRRA").val("");
        $("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA").val("");
        $("#InformacaoRRAAcessoria_InformacaoRRA_DescricaoRRA").val("");
        $("#InformacaoRRAAcessoria_InformacaoRRA_QuantidadeMesesRRA").val("");
        $("#InformacaoRRAAcessoria_InformacaoRRA_DespesaProcessoJudicial_ValorDespesaCustasJudiciais").val("");
        $("#InformacaoRRAAcessoria_InformacaoRRA_DespesaProcessoJudicial_ValorDespesaAdvogado").val("");
    }

    mudarObrigatoriedadeCampo(false, $("[id$='InformacaoRRAAcessoria_InformacaoRRA_DespesaProcessoJudicial_ValorDespesaCustasJudiciais']"));
    mudarObrigatoriedadeCampo(false, $("[id$='InformacaoRRAAcessoria_InformacaoRRA_DespesaProcessoJudicial_ValorDespesaAdvogado']"));
}

function ControlaMascaraProcesso() {
    $("#InformacaoRRAAcessoria_InformacaoRRA_TipoProcessoRRA").change(function () {
        ControlaObrigatoriedadeProcesso();
    });

    $("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA").focus(function () {
        ControlaMascaraProcessoFocus();
    });

    $("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA").blur(function () {
        ControlaMascaraProcessoBlur();
    });
}

function ControlaObrigatoriedadeProcesso() {
    if ($("#InformacaoRRAAcessoria_InformacaoRRA_TipoProcessoRRA").val() == 1) {
        mudarObrigatoriedadeCampo(false, $("[id$='InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA']"));
    }
    else if ($("#InformacaoRRAAcessoria_InformacaoRRA_TipoProcessoRRA").val() == 2) {
        mudarObrigatoriedadeCampo(true, $("[id$='InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA']"));
    }
}

function ControlaMascaraProcessoFocus() {
    removeMascara("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA");

    if ($("#InformacaoRRAAcessoria_InformacaoRRA_TipoProcessoRRA").val() == 1) {
        $("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA").attr("maxlength", 21);
    }
    else if ($("#InformacaoRRAAcessoria_InformacaoRRA_TipoProcessoRRA").val() == 2) {
        $("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA").attr("maxlength", 25);
    }
}

function ControlaMascaraProcessoBlur() {
    $("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA").attr("maxlength", 25);

    if ($("#InformacaoRRAAcessoria_InformacaoRRA_TipoProcessoRRA").val() == 1) {
        if ($("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA").val().length == 17) {
            aplicaMascara("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA", '99999.999999/9999-99');
        } else if ($("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA").val().length == 25) {
            aplicaMascara("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA", '9999999.99999999/9999-99');
        }
    }
    else if ($("#InformacaoRRAAcessoria_InformacaoRRA_TipoProcessoRRA").val() == 2) {
        aplicaMascara("#InformacaoRRAAcessoria_InformacaoRRA_NumeroProcessoRRA", '9999999-99-9999-9-99-9999');
    }
}

function AbrirModalListaAdvogados(obj) {
    $("#dialog-lista-advogados").dialog(
        {
            appendTo: 'body',
            position: ['center', 'center'],
            dialogClass: 'modal',
            draggable: false,
            resizable: false,
            width: 800,
            title: 'Advogados informados para o RRA:',
            modal: true, open: function () {
                $("#dialog-lista-advogados").find("span").html(obj);
                $(".ui-dialog").scrollTop("0");
            },
            buttons: [
                {
                    text: "Cancelar",
                    "class": 'btn btn-primary btn-cancelar',
                    click: function () { $(this).dialog("close"); }
                },
            ]
        });
};
