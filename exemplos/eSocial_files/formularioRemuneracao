const removeById = (arr, numeroInscricao) => {
    const requiredIndex = arr.findIndex(el => {
        return el.NumeroInscricao === numeroInscricao;
    });
    if (requiredIndex === -1) {
        return false;
    };
    return !!arr.splice(requiredIndex, 1);
};

