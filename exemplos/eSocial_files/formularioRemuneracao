            $('#EventoAcessorio_DemonstrativosValoresDevidos_0__InformacaoPeriodoApuracao_ListaIdeEstabelecimentoLotacao_0__NumeroInscricao').val(padNumeroInscricaoEstabelecimento(tokens[0], tokens[1])).blur();
            setTimeout(() => $('#EventoAcessorio_DemonstrativosValoresDevidos_0__InformacaoPeriodoApuracao_ListaIdeEstabelecimentoLotacao_0__NumeroInscricao').valid(), 100);
        }
    }
    else if ($('#StringDicionarioTipoNumeroInscricaoPorDemonstrativo').length > 0
        && $('#StringDicionarioTipoNumeroInscricaoPorDemonstrativo').val().length > 0
        && $("#RubricaAcessoria_Identificador").length > 0
        && $("#RubricaAcessoria_Identificador").val().length > 0) {
        // Formato: idDemonstrativo=tpInscr,nrInscr;
        const tokens = $('#StringDicionarioTipoNumeroInscricaoPorDemonstrativo').val().split(';');
        const identificadorDemonstrativo = $("#RubricaAcessoria_Identificador").val();

        let i;
        for (i = 0; i < tokens.length; i++) {
            if (tokens[i].startsWith(identificadorDemonstrativo)) {
                const infoEstabelecimento = tokens[i].replace(`${identificadorDemonstrativo}=`, '').split(',');

                if (infoEstabelecimento.length === 2) {
                    $('#EventoAcessorio_DemonstrativosValoresDevidos_0__InformacaoPeriodoApuracao_ListaIdeEstabelecimentoLotacao_0__TipoInscricao').val(infoEstabelecimento[0]);
                    $('#EventoAcessorio_DemonstrativosValoresDevidos_0__InformacaoPeriodoApuracao_ListaIdeEstabelecimentoLotacao_0__NumeroInscricao').val(padNumeroInscricaoEstabelecimento(infoEstabelecimento[0], infoEstabelecimento[1])).blur();
                    setTimeout(() => $('#EventoAcessorio_DemonstrativosValoresDevidos_0__InformacaoPeriodoApuracao_ListaIdeEstabelecimentoLotacao_0__NumeroInscricao').valid(), 100);
                }

                break;
            }
        }
    }
}

function padNumeroInscricaoEstabelecimento(tipoInscricao, numeroInscricao) {
    switch (tipoInscricao) {
        case "1":
        case "3":
            return pad(numeroInscricao, 14, '0');
        case "4":
            return pad(numeroInscricao, 12, '0');
    }
}

