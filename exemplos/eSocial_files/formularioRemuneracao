function ConfigurarObrigatoriedade(seletoresElementosObrigatorios, seletoresElementosFacultativos) {
    for (var i = 0; i < seletoresElementosObrigatorios.length; i++) {
        var label = $("#" + seletoresElementosObrigatorios[i]).parent().siblings("label").first();

        if (label.children().length === 0) {
            label.append("<em class='tag-campo-obrigatorio'>*</em>");
        }

        var input = $("#" + seletoresElementosObrigatorios[i]);

        input.addClass("required");
        input.attr("data-val-required", "Campo de preenchimento obrigatório.");
        input.attr("aria-required", "true");
        input.attr("aria-describedby", seletoresElementosObrigatorios[i] + "-error");
        input.attr("aria-invalid", "false");

        if (input.val() === "") {
            label.effect("highlight", {}, 1000);
        }
    }

    for (i = 0; i < seletoresElementosFacultativos.length; i++) {
        label = $("#" + seletoresElementosFacultativos[i]).parent().siblings("label").first();

        if (label.children().length > 0) {
            label.children()[0].remove();
        }

        input = $("#" + seletoresElementosFacultativos[i]);

        input.removeClass("required");
        input.removeAttr("data-val-required");
        input.removeAttr("aria-required");
        input.removeAttr("aria-describedby");
        input.removeAttr("aria-invalid");

        if (input.val() !== "") {
            label.effect("highlight", {}, 1000);
        }

        input.blur();
    }
}

